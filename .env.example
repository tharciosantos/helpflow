# GitHub OAuth
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Database (Supabase)
# DATABASE_URL: use a URL do pooler/transação (porta 6543)
# DIRECT_URL:   use a conexão direta (porta 5432) — necessária para migrations
DATABASE_URL=
DIRECT_URL=

# Vercel Cron Job — autenticação do endpoint /api/cron/keep-alive
# Gere um valor aleatório seguro e configure também no painel da Vercel
CRON_SECRET=

# Testes Cypress — necessário para criar usuários com role AGENT nos testes E2E
# O cypress.config.js lê esse valor via process.env.CYPRESS_TEST_SECRET
# Escolha qualquer string segura (ex: openssl rand -base64 20) e use o mesmo valor no .env do servidor
CYPRESS_TEST_SECRET=
